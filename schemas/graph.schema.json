{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "edges": {
      "items": {
        "properties": {
          "artifact_kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "rel": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "target",
          "rel",
          "artifact_kind"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "nodes": {
      "items": {
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "decision",
              "artifact"
            ],
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "kind",
          "label"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "nodes",
    "edges"
  ],
  "type": "object"
}
